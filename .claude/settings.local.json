          {
            "type": "command",
            "command": "cd \"C:\\Users\\Jhaider\\OneDrive\\Desktop\\audio_texto\" && python graph-posttool.py",
            "timeout": 20,
            "async": true
          }
        ]
      }
    ]
  }
}
