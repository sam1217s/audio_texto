            "command": "cd \"C:\\Users\\Jhaider\\OneDrive\\Desktop\\audio_texto\" && python graph-hook.py",
            "timeout": 20
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
